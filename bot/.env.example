# Discord — from https://discord.com/developers/applications
DISCORD_TOKEN=your_bot_token_here
CLIENT_ID=your_application_client_id_here
GUILD_ID=your_discord_server_id_here
DISCORD_PUBLIC_KEY=your_application_public_key_here

# GitHub — personal access token with repo write access
# https://github.com/settings/tokens (fine-grained, Contents: read+write)
GITHUB_TOKEN=your_github_pat_here

# Google Gemini — free at aistudio.google.com
GEMINI_API_KEY=your_gemini_api_key_here